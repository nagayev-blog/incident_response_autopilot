{
  "permissions": {
    "allow": [
      "Bash(uv sync)",
      "Bash(uv add:*)",
      "Bash(uv run pytest:*)",
      "Bash(uv run ruff:*)",
      "Bash(uv run mypy:*)",
      "Bash(uv run python:*)",
      "Bash(uv run streamlit:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(mkdir:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(grep:*)",
      "Bash(rg:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(uv run python -m src.rag.ingestion:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(curl:*)",
      "Bash(sudo:*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "env": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  }
}
